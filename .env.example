# AI Visibility Explorer — optional configuration
# Copy this file to ".env" and fill in values only if you want the OPTIONAL features.
# The MVP runs fully WITHOUT any of these keys (paste responses or upload CSVs).
#
#   cp .env.example .env
#
# NEVER commit your real .env file. It is already listed in .gitignore.

# --- Optional LLM adapters (Phase 2) ---------------------------------------
# Used only if you choose to (a) collect live AI responses, or
# (b) generate an AI-written narrative summary. Deterministic templates are
# always the default and require no key.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=

# --- Page audit politeness --------------------------------------------------
# User-Agent string sent when auditing public web pages. Be honest and identifiable.
AIVX_USER_AGENT=AIVisibilityExplorer/0.1 (+portfolio-project; contact via GitHub)

# Seconds to wait before giving up on a page request during audits.
AIVX_REQUEST_TIMEOUT=10
